# Custom auth header for the backend (e.g. x-auth-token).
API_AUTH_HEADER=x-auth-token
API_AUTH_VALUE=your_server_side_token_here
# UploadThing secret key for file uploads.
UPLOADTHING_SECRET=your_uploadthing_secret_here
