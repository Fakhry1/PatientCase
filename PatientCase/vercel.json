{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/specialties", "destination": "/api/specialties" },
    { "source": "/api/uploadthing", "destination": "/api/uploadthing" },
    { "source": "/api/cases/webhook/case-created", "destination": "/api/cases/webhook/case-created" },
    { "source": "/api/cases/:caseId/attachments", "destination": "/api/cases/[caseId]/attachments" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
